# =============================================
# n8n Credentials - Copy this file to .env
# and fill in your actual values
# =============================================

# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Service Account credentials
# Download the JSON key file from Google Cloud Console
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json

# Google Spreadsheet ID
# Found in your Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# n8n Configuration (if self-hosting)
N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here
